        "\n",
        "n = int(input(\"Ingresa un número: \"))\n",
        "suma = 0\n",
        "\n",
        "for i in range(1, n + 1):\n",
        "    suma = suma + i\n",
        "\n",
        "print(\"La suma es:\", suma)"
